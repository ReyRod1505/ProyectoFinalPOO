<!DOCTYPE web-app PUBLIC
        "-//Sun Microsystems, Inc.//DTD Web Application 2.3//EN"
        "http://java.sun.com/dtd/web-app_2_3.dtd" >

<web-app>
  <display-name>OpenXava Application</display-name>

  <servlet>
    <servlet-name>AccesoExamen</servlet-name>
    <servlet-class>ni.edu.uam.ProyectoFinalPOO.rest.AccesoExamenServlet</servlet-class>
  </servlet>
  <servlet>
    <servlet-name>EnviarExamen</servlet-name>
    <servlet-class>ni.edu.uam.ProyectoFinalPOO.rest.EnviarExamenServlet</servlet-class>
  </servlet>

  <servlet-mapping>
    <servlet-name>AccesoExamen</servlet-name>
    <url-pattern>/api/examen/acceso</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>EnviarExamen</servlet-name>
    <url-pattern>/api/examen/enviar</url-pattern>
  </servlet-mapping>

</web-app>