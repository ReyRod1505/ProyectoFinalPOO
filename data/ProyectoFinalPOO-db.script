ALTER TABLE PUBLIC.RESPUESTA ALTER COLUMN OID RESTART WITH 2
CREATE MEMORY TABLE PUBLIC.RESULTADO(OID INTEGER GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ACIERTOS INTEGER NOT NULL,OBSERVACION VARCHAR(255),PORCENTAJE DOUBLE NOT NULL,TOTALPREGUNTAS INTEGER NOT NULL,SESION_OID INTEGER)
ALTER TABLE PUBLIC.RESULTADO ALTER COLUMN OID RESTART WITH 2
CREATE MEMORY TABLE PUBLIC.SESIONTEST(OID INTEGER GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,ESTADO VARCHAR(255),FECHAFIN TIMESTAMP,FECHAINICIO TIMESTAMP,FORMA VARCHAR(255),ESTUDIANTE_OID INTEGER,CONSTRAINT FKSP8G78SDPOTD3QGL4XRX1K4UI FOREIGN KEY(ESTUDIANTE_OID) REFERENCES PUBLIC.ESTUDIANTE(OID))
ALTER TABLE PUBLIC.SESIONTEST ALTER COLUMN OID RESTART WITH 5
ALTER TABLE PUBLIC.RESPUESTA ADD CONSTRAINT FKBRSW4S927HY3GUMB73LUKTP0A FOREIGN KEY(SESION_OID) REFERENCES PUBLIC.SESIONTEST(OID)
