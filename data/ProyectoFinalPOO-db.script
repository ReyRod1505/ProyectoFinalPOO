CREATE MEMORY TABLE PUBLIC.ESTUDIANTE(OID INTEGER GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,APELLIDOS VARCHAR(60),CARRERA VARCHAR(40),EMAIL VARCHAR(80),FECHANACIMIENTO DATE,NOMBRES VARCHAR(60))
ALTER TABLE PUBLIC.ESTUDIANTE ALTER COLUMN OID RESTART WITH 3
